GEMINI_API_KEY=

# QP cost checkpoint: cheap first, Flash rescue.
GEMINI_QP_LITE_FIRST=true
GEMINI_QP_PRIMARY_MODEL=gemini-2.5-flash-lite
GEMINI_QP_PRIMARY_RETRIES=2
GEMINI_QP_RESCUE_MODEL=gemini-2.5-flash
GEMINI_QP_RESCUE_RETRIES=0
GEMINI_MAX_RETRIES=3

# Hybrid QP/MS anchor mode:
# - QP page extraction remains cheap Lite-first by default.
# - Gemini receives only page-local saved-MS IDs, not the full paper list.
# - Deep/nested page-local IDs can use Flash-first; simple pages stay Lite.
GEMINI_QP_MS_ANCHOR_FLASH_FIRST=false
GEMINI_QP_DEEP_ANCHOR_FLASH_FIRST=false
GEMINI_QP_DEEP_ANCHOR_MIN_DEPTH=3
PAPERLY_QP_LOCAL_SKELETON_FIRST=true
PAPERLY_QP_LOCAL_SKELETON_MIN_COVERAGE=0.70
PAPERLY_QP_LOCAL_SKELETON_FUZZY_DIAGRAMS=false
PAPERLY_QP_LOCAL_SKELETON_FUZZY_DIAGRAM_MIN_SIMILARITY=0.78

# Targeted missing-ID rescue is local-first, then Lite-first. Enable Flash only
# for an explicit emergency quality run.
GEMINI_QP_TARGETED_RESCUE_FLASH_FIRST=false
PAPERLY_RESCUE_MAX_PAGES=4

# Keep whole-document Gemini fallback off unless doing an emergency recovery run.
GEMINI_ALLOW_FILES_FALLBACK=false

# Shared-key production throttle.
PAPERLY_MAX_CONCURRENT_REQUESTS=5
PAPERLY_MAX_CONCURRENT_PDF_EXTRACTIONS=2
GEMINI_GLOBAL_MAX_CONCURRENCY=3
GEMINI_MIN_SECONDS_BETWEEN_CALLS=1.25

# Optional cost-estimation overrides.
USD_TO_INR=84
GEMINI_FLASH_LITE_INPUT_USD_PER_M=0.10
GEMINI_FLASH_LITE_OUTPUT_USD_PER_M=0.40
GEMINI_FLASH_INPUT_USD_PER_M=0.30
GEMINI_FLASH_OUTPUT_USD_PER_M=2.50
